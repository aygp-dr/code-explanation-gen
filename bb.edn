{:paths ["src"]
 :deps {org.babashka/cli {:mvn/version "0.8.61"}}
 :tasks
 {:override-builtin true
  run {:doc "Generate line-by-line code explanations"
       :task (apply (requiring-resolve 'code_explanation_gen.core/-main) *command-line-args*)}
  scan {:doc "Scan current directory"
        :task (apply (requiring-resolve 'code_explanation_gen.core/-main) ["--dir" "."])}}}
